# =============================================================================
# .gitignore — EventViewer-To-CSV
# =============================================================================

# -----------------------------------------------------------------------------
# Rust
# -----------------------------------------------------------------------------
# Compiled output for the Tauri backend
target/
src-tauri/target/

# Rust backup files generated by older versions of rustfmt
**/*.rs.bk

# Cargo.lock — remove the line below for binary applications (keep it tracked
# to ensure reproducible builds). Uncomment only for library crates.
# Cargo.lock

# -----------------------------------------------------------------------------
# Node / npm
# -----------------------------------------------------------------------------
node_modules/

# Local environment files — may contain secrets; never commit these
.env
.env.*
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# Vite / build outputs
# -----------------------------------------------------------------------------
dist/
build/

# Vite cache
.vite/

# -----------------------------------------------------------------------------
# Tauri
# -----------------------------------------------------------------------------
# Tauri-specific WiX toolchain (downloaded at build time, not source)
src-tauri/WixTools/

# Generated files created by `tauri build` / plugin generators
src-tauri/gen/

# -----------------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encdata
desktop.ini
$RECYCLE.BIN/

# Linux
*~

# -----------------------------------------------------------------------------
# Editors and IDEs
# -----------------------------------------------------------------------------
# VS Code
.vscode/

# JetBrains IDEs (IntelliJ, CLion, etc.)
.idea/

# Vim / Neovim swap files
*.swp
*.swo
*.swn

# Emacs
\#*\#
.\#*

# -----------------------------------------------------------------------------
# Logs and diagnostics
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Project-specific — DO NOT ignore
# -----------------------------------------------------------------------------
# suspicious-commands.txt is an important project file that defines enrichment
# patterns. It must remain tracked in version control.
!suspicious-commands.txt
